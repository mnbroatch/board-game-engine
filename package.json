{
  "name": "board-game-engine",
  "version": "0.0.11",
  "description": "wip board game engine",
  "main": "dist/board-game-engine.cjs",
  "module": "dist/board-game-engine.mjs",
  "exports": {
    ".": {
      "import": "./dist/board-game-engine.mjs",
      "require": "./dist/board-game-engine.cjs"
    }
  },
  "scripts": {
    "test": "playwright test",
    "test:coverage": "npm run build:coverage && cross-env COVERAGE=1 playwright test && nyc merge .nyc_output/run .nyc_output/out.json && nyc report --reporter=html --reporter=text",
    "build:coverage": "cross-env COVERAGE=1 node scripts/build.mjs",
    "test:e2e": "playwright test",
    "test:e2e:debug": "cross-env DEBUG_CONSOLE=1 playwright test",
    "test:e2e:install": "playwright install firefox",
    "serve": "http-server . -p 5174 -c-1",
    "lint": "eslint .",
    "build": "node scripts/build.mjs",
    "prepublishOnly": "npm run build"
  },
  "author": "Matthew Broatch",
  "license": "ISC",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "esbuild": "^0.24.0",
    "esbuild-plugin-istanbul": "^0.3.0",
    "eslint": "",
    "eslint-config-standard": "^16.0.3",
    "eslint-plugin-import": "^2.3.0",
    "http-server": "^14.1.1",
    "nyc": "^15.1.0",
    "standard": "^16.0.4",
    "@playwright/test": "^1.49.0"
  },
  "dependencies": {
    "@mnbroatch/boardgame.io": "0.0.1",
    "expr-eval": "^2.0.2",
    "wackson": "^1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnbroatch/board-game-engine.git"
  },
  "bugs": {
    "url": "https://github.com/mnbroatch/board-game-engine/issues"
  },
  "homepage": "https://github.com/mnbroatch/board-game-engine#readme"
}
